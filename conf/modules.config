params {
    // ensure outputDir and tracedir are set correctly after including profile options
    outputDir = outputDir
    tracedir = "${params.outputDir}/pipeline_info"
}

process {

    errorStrategy = 'finish'

    withName: '.*POOL_INPUTS:CONCAT_INPUTS.*' {
        ext.prefix = { "${meta.id}.pooled.fastq.gz"}
    }

    // Cache downloaded/built reference assets so repeat runs with the same --genome
    // reuse them instead of rebuilding. Point params.genome_cache_dir at shared
    // storage to share a genome build across runs and users. storeDir is disabled
    // (null) when genome_cache_dir is unset.
    // The (.*:)? prefix matches PREPARE_GENOME whether it is the top-level
    // subworkflow (normal run) or nested under another entry (e.g. MAKE_REFERENCE).
    withName: '(.*:)?PREPARE_GENOME:DOWNLOAD_GENOME' {
        storeDir = { params.genome_cache_dir ? "${params.genome_cache_dir}/${params.genome}/download" : null }
    }
    withName: '(.*:)?PREPARE_GENOME:BWA_INDEX_REF' {
        storeDir = { params.genome_cache_dir ? "${params.genome_cache_dir}/${params.genome}/bwa_index" : null }
    }
    withName: '(.*:)?PREPARE_GENOME:KHMER_UNIQUEKMERS' {
        storeDir = { params.genome_cache_dir ? "${params.genome_cache_dir}/${params.genome}/effective_genome_size" : null }
    }
    withName: '(.*:)?PREPARE_GENOME:SPLIT_REF_CHROMS' {
        storeDir = { params.genome_cache_dir ? "${params.genome_cache_dir}/${params.genome}/chroms" : null }
    }
    withName: '(.*:)?PREPARE_GENOME:GTF2BED' {
        storeDir = { params.genome_cache_dir ? "${params.genome_cache_dir}/${params.genome}/gene_info" : null }
    }
    // Keep blacklist subprocesses separate because BEDTOOLS_GETFASTA and
    // BWA_INDEX_BL both emit versions.yml.
    withName: '(.*:)?PREPARE_GENOME:PREPARE_BLACKLIST:BEDTOOLS_GETFASTA' {
        storeDir = { params.genome_cache_dir ? "${params.genome_cache_dir}/${params.genome}/blacklist/fasta" : null }
    }
    withName: '(.*:)?PREPARE_GENOME:PREPARE_BLACKLIST:BWA_INDEX_BL' {
        storeDir = { params.genome_cache_dir ? "${params.genome_cache_dir}/${params.genome}/blacklist/index" : null }
    }

}
