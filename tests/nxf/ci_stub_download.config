params {
    config_profile_name = 'Test URL-based genome download (stubs)'
    config_profile_description = 'Exercises the reference-genome download+build branch (registry URLs, no index_dir) via stubs on continuous integration'

    input = "${projectDir}/assets/samplesheet_test.csv"
    genome = 'test_download'

    max_cpus = 2
    max_memory = '6.GB'
    max_time   = '6.h'

    publish_dir_mode = "symlink"

    // no index_dir: forces the download+build path for a genome that provides URLs
    index_dir = null
    read_length = 50

    // this test targets the reference download+build path; QC/fastq_screen is
    // unrelated and needs external DBs, so disable it to keep the stub self-contained
    run_qc = false

    genomes {
        // exercises the download+build decision/branch wiring under -stub. The "URLs"
        // are small local fixtures so Nextflow staging never hits the network; a .fa
        // blacklist keeps PREPARE_BLACKLIST on the fasta branch (skips BEDTOOLS_GETFASTA,
        // which has no stub). Network transfer and decompression require a live test.
        'test_download' {
            species = "test"
            fasta_url = "${projectDir}/tests/data/test_download.fa"
            gtf_url = "${projectDir}/tests/data/test_download.gtf"
            blacklist_url = "${projectDir}/tests/data/test_download.blacklist.fa"
            read_length = 50
            meme_motifs = null
            bioc_txdb = 'TxDb.Scerevisiae.UCSC.sacCer3.sgdGene'
            bioc_annot = 'org.Sc.sgd.db'
        }
    }
    sicer_species = "sacCer1"
}

process {
    cpus = 1
    memory = '1 GB'
}

executor {
    queueSize = 20
}
